<UserControl
    x:Class="WinUIShell.FlyoutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="360">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ToggleCard">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefault}"/>
            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
            <Setter Property="Width" Value="154"/>
            <Setter Property="Height" Value="82"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              BorderBrush="{TemplateBinding BorderBrush}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{ThemeResource ControlFillColorSecondary}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{ThemeResource ControlFillColorTertiary}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PowerBtn">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefault}"/>
            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              BorderBrush="{TemplateBinding BorderBrush}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{ThemeResource ControlFillColorSecondary}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{ThemeResource ControlFillColorTertiary}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="Quick settings" FontSize="16" FontWeight="SemiBold"
                   Margin="16,16,16,4" Grid.Row="0"/>
        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefault}" 
                   Margin="14,4,14,0" Grid.Row="1"/>

        <StackPanel x:Name="TogglePanel" Orientation="Horizontal" Margin="14,10,14,0" Grid.Row="2" Spacing="8">
            <Button x:Name="WifiButton" Style="{StaticResource ToggleCard}" Click="OnWifiToggle">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="6">
                    <FontIcon x:Name="WifiIcon" Glyph="&#xE701;" FontSize="22" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="WifiLabel" Text="Wi-Fi" FontSize="12" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtButton" Style="{StaticResource ToggleCard}" Click="OnBtToggle">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="6">
                    <FontIcon x:Name="BtIcon" Glyph="&#xE702;" FontSize="22" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="BtLabel" Text="Bluetooth" FontSize="12" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefault}"
                   Margin="14,10,14,0" Grid.Row="3"/>

        <StackPanel Margin="14,10,14,0" Grid.Row="4" Spacing="4">
            <TextBlock x:Name="VolumeLabel" Text="Volume" FontSize="13"/>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <FontIcon Grid.Column="0" Glyph="&#xE767;" FontSize="18" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <Slider Grid.Column="1" x:Name="VolumeSlider" Minimum="0" Maximum="100" StepFrequency="1" ValueChanged="OnVolumeChanged" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <StackPanel x:Name="BrightnessPanel" Margin="14,10,14,0" Grid.Row="5" Spacing="4" Visibility="Collapsed">
            <TextBlock x:Name="BrightnessLabel" Text="Brightness" FontSize="13"/>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <FontIcon Grid.Column="0" Glyph="&#xE706;" FontSize="18" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <Slider Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="100" StepFrequency="1" ValueChanged="OnBrightnessChanged" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefault}"
                   Margin="14,10,14,0" Grid.Row="6"/>

        <TextBlock x:Name="NetworkInfo" FontSize="12" Margin="16,10,16,10"
                   Foreground="{ThemeResource TextFillColorSecondary}" Grid.Row="7"/>

        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefault}"
                   Margin="14,0,14,0" Grid.Row="8"/>

        <StackPanel Orientation="Horizontal" Margin="14,10,14,14"
                    HorizontalAlignment="Center" Spacing="6" Grid.Row="9">
            <Button Style="{StaticResource PowerBtn}" Click="OnLock">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE72E;" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Lock" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PowerBtn}" Click="OnSleep">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE708;" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sleep" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PowerBtn}" Click="OnRestart">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE72C;" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Restart" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PowerBtn}" Click="OnShutdown">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="4">
                    <FontIcon Glyph="&#xE7E8;" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Shut down" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
