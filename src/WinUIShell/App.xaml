<Application
    x:Class="WinUIShell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="BgBase" Color="#FF1C1C1C"/>
            <SolidColorBrush x:Key="BgSurface" Color="#FF252525"/>
            <SolidColorBrush x:Key="BgElevated" Color="#FF2D2D2D"/>
            <SolidColorBrush x:Key="BgHover" Color="#FF3A3A3A"/>
            <SolidColorBrush x:Key="BgPressed" Color="#FF454545"/>
            <SolidColorBrush x:Key="BgCard" Color="#FF2B2B2B"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFF0F0F0"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#FFA0A0A0"/>
            <SolidColorBrush x:Key="TextMuted" Color="#FF707070"/>
            <SolidColorBrush x:Key="BorderColor" Color="#FF404040"/>
            <SolidColorBrush x:Key="Accent" Color="#FF60B0FF"/>

            <Style x:Key="ToggleCard" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Width" Value="154"/>
                <Setter Property="Height" Value="82"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="22"/>
            </Style>

            <Style x:Key="PowerButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Width" Value="78"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
